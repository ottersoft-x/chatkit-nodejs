{
  "name": "chatkit-bun",
  "version": "0.0.2",
  "module": "./src/index.ts",
  "types": "./types/index.d.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.ts"
    }
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/nunjucks": "^3.2.6",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "dependencies": {
    "@openai/agents": "^0.11.5",
    "nunjucks": "^3.2.4",
    "zod": "^4.4.3"
  },
  "scripts": {
    "test": "bun test",
    "build:types": "bunx tsc -p tsconfig.types.json",
    "typecheck": "bunx tsc --noEmit",
    "verify": "bun run typecheck && bun test",
    "verify:parity": "bun run verify && bun scripts/verify-parity.ts"
  }
}
